# API 配置
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 文件存储
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=524288000  # 500MB
TEMP_DIR=./temp
OUTPUT_DIR=./outputs

# NE301 项目路径（Docker 环境通常为 /workspace）
NE301_PROJECT_PATH=/workspace

# ST Edge AI 路径（可选，Docker 镜像中已配置）
STEDGEAI_PATH=/opt/stedgeai

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
