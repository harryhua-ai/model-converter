# API 配置
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Docker 配置
NE301_DOCKER_IMAGE=camthink/ne301-dev:latest

# 文件路径
UPLOAD_DIR=./uploads
TEMP_DIR=./temp
OUTPUT_DIR=./outputs
MAX_UPLOAD_SIZE=524288000

# 日志配置
LOG_LEVEL=INFO

# 安全配置 - HIGH-2026-005: CORS 配置
# 开发环境（DEBUG=true）: 默认允许 localhost，可使用以下默认值
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173
#
# 生产环境（DEBUG=false）: 必须显式配置允许的域名
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173
